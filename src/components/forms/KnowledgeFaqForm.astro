<form id="form-faq-manual" class="space-y-4">
    <div>
      <label class="block text-[14px] font-medium text-ink mb-2">Kategori</label>
      <input type="text" id="faq_category" class="w-full bg-surface-card border border-hairline-strong rounded-[8px] px-4 py-3 text-[15px] text-ink focus:outline-none focus:border-ink" required placeholder="Cth: Penggunaan VClass">
    </div>
    <div>
      <label class="block text-[14px] font-medium text-ink mb-2">Pertanyaan</label>
      <textarea id="faq_question" rows="2" class="w-full bg-surface-card border border-hairline-strong rounded-[8px] px-4 py-3 text-[15px] text-ink focus:outline-none focus:border-ink" required placeholder="Cth: Bagaimana cara absen?"></textarea>
    </div>
    <div>
      <label class="block text-[14px] font-medium text-ink mb-2">Jawaban</label>
      <textarea id="faq_answer" rows="3" class="w-full bg-surface-card border border-hairline-strong rounded-[8px] px-4 py-3 text-[15px] text-ink focus:outline-none focus:border-ink" required placeholder="Cth: Klik menu presensi lalu isi form..."></textarea>
    </div>
    <button type="submit" class="w-full bg-primary text-white rounded-full py-3 text-[15px] font-medium hover:bg-primary-active transition-colors shadow-sm">
      Simpan FAQ
    </button>
  </form>
