---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Modal from '../../components/common/Modal.astro';
---
<DashboardLayout title="Dashboard Utama">
  <div class="max-w-[1200px] mx-auto w-full">
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-10">
      <div>
        <h1 class="font-serif text-3xl md:text-4xl text-ink tracking-tight mb-2">Daftar Project</h1>
        <p class="text-body text-[16px]">Kelola asisten AI untuk setiap mata pelajaran.</p>
      </div>
      <button id="btn-open-create-modal" class="bg-primary text-white rounded-full px-6 py-3 text-[15px] font-medium hover:bg-primary-active transition-colors shadow-sm w-full md:w-auto">
        <i class="fa-solid fa-plus mr-2"></i> Buat Project
      </button>
    </div>

    <div id="project-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <div class="col-span-full text-center py-10 text-muted-soft"><i class="fa-solid fa-spinner fa-spin text-2xl"></i><br>Memuat data...</div>
    </div>
  </div>

  <Modal id="modal-create-project" title="Project Baru">
    <form id="form-create-project" class="space-y-6">
      <div>
        <label class="block text-[14px] font-medium text-ink mb-2">Nama Project (Mata Pelajaran)</label>
        <input type="text" id="project_name" class="w-full bg-canvas-soft border border-hairline-strong rounded-[8px] px-4 py-3 text-[15px] text-ink focus:border-ink focus:outline-none" required placeholder="Cth: Informatika Kelas 10">
      </div>
      <button type="submit" class="w-full bg-primary text-white rounded-full py-3 text-[15px] font-medium hover:bg-primary-active transition-colors">
        Buat Project
      </button>
    </form>
  </Modal>
</DashboardLayout>
